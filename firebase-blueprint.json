{
  "entities": {
    "Publication": {
      "title": "Publication",
      "description": "An academic paper, book, or article authored by the professor",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the publication"
        },
        "authors": {
          "type": "string",
          "description": "Comma-separated list of authors"
        },
        "type": {
          "type": "string",
          "enum": ["journal", "book", "conference", "other"],
          "description": "Type of the publication"
        },
        "publisher": {
          "type": "string",
          "description": "The publishing company or journal name"
        },
        "year": {
          "type": "integer",
          "description": "Year of publication"
        },
        "link": {
          "type": "string",
          "format": "uri",
          "description": "URL link to the publication"
        },
        "description": {
          "type": "string",
          "description": "Abstract or short description of the work"
        },
        "dateAdded": {
          "type": "string",
          "format": "date",
          "description": "Timestamp when this item was logged"
        }
      },
      "required": ["title", "authors", "type", "year"]
    },
    "Project": {
      "title": "Project",
      "description": "A research project or grant in which the professor is involved",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the research project"
        },
        "status": {
          "type": "string",
          "enum": ["ongoing", "completed"],
          "description": "The active status of the study"
        },
        "role": {
          "type": "string",
          "description": "The specific role of the professor (e.g. Principal Investigator)"
        },
        "description": {
          "type": "string",
          "description": "The abstract or focus area of the research"
        },
        "timeline": {
          "type": "string",
          "description": "Years active (e.g. 2021 - 2023)"
        },
        "funding": {
          "type": "string",
          "description": "Sponsoring bodies or grants"
        }
      },
      "required": ["title", "status", "role", "description"]
    },
    "BlogPost": {
      "title": "BlogPost",
      "description": "An academic blog post or department news feed item",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The headline of the article"
        },
        "content": {
          "type": "string",
          "description": "Full markdown or text body of the post"
        },
        "excerpt": {
          "type": "string",
          "description": "Short summary of the article"
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "Date of publication"
        },
        "category": {
          "type": "string",
          "enum": ["Announcements", "Academic Notes", "Conferences"],
          "description": "The category classification"
        },
        "imageUrl": {
          "type": "string",
          "format": "uri",
          "description": "The main visual header link"
        }
      },
      "required": ["title", "content", "excerpt", "date", "category"]
    },
    "GalleryImage": {
      "title": "GalleryImage",
      "description": "A photographed record of professional academic events",
      "type": "object",
      "properties": {
        "imageUrl": {
          "type": "string",
          "format": "uri",
          "description": "Source URL of the illustration or photo"
        },
        "caption": {
          "type": "string",
          "description": "Contextual description of the photographed event"
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "Approximate date of the photograph"
        },
        "category": {
          "type": "string",
          "enum": ["Lectures", "Conferences", "Fieldwork"],
          "description": "Category classification"
        }
      },
      "required": ["imageUrl", "caption", "date", "category"]
    },
    "ContactMessage": {
      "title": "ContactMessage",
      "description": "An inquiry message transmitted via the contact portal",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The inquirer's full name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The inquirer's return email address"
        },
        "subject": {
          "type": "string",
          "description": "Title of the correspondence"
        },
        "message": {
          "type": "string",
          "description": "Full message content"
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "Date and hour of receipt"
        },
        "read": {
          "type": "boolean",
          "description": "Read status indicator"
        }
      },
      "required": ["name", "email", "subject", "message", "date", "read"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Security profile block for a website visitor",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "likedPublications": { "type": "array", "items": { "type": "string" } },
        "purchasedPublications": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "isAdmin": { "type": "boolean" }
      },
      "required": ["uid", "email", "displayName", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial record log of an acquisition or support donation",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string", "format": "email" },
        "userName": { "type": "string" },
        "type": { "type": "string", "enum": ["purchase", "donation"] },
        "amount": { "type": "number" },
        "publicationId": { "type": "string" },
        "publicationTitle": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "success", "failed"] },
        "reference": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userEmail", "userName", "type", "amount", "status", "reference", "date"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Opinion or feedback submitted under a publication, topic, or post",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "publicationId": { "type": "string" },
        "publicationTitle": { "type": "string" },
        "text": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] }
      },
      "required": ["userId", "userName", "publicationId", "publicationTitle", "text", "date", "status"]
    },
    "DonationSettings": {
      "title": "DonationSettings",
      "description": "Customizable configuration for portal-wide donations",
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "suggestedAmounts": { "type": "array", "items": { "type": "number" } }
      },
      "required": ["enabled", "title", "description", "suggestedAmounts"]
    },
    "PaymentKeys": {
      "title": "PaymentKeys",
      "description": "Administrator key details for pay gateways",
      "type": "object",
      "properties": {
        "paystackPublicKey": { "type": "string" },
        "paystackSecretKey": { "type": "string" },
        "opayPublicKey": { "type": "string" },
        "opaySecretKey": { "type": "string" },
        "activeGateway": { "type": "string", "enum": ["paystack", "opay"] },
        "paymentSystemsEnabled": { "type": "boolean" }
      },
      "required": ["paystackPublicKey", "paystackSecretKey", "activeGateway", "paymentSystemsEnabled"]
    },
    "FavoriteItem": {
      "title": "FavoriteItem",
      "description": "Bookmarked content details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "contentId": { "type": "string" },
        "contentType": { "type": "string", "enum": ["journal", "article", "publication", "blog", "project"] },
        "title": { "type": "string" },
        "dateAdded": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "contentId", "contentType", "title", "dateAdded"]
    },
    "CMSPage": {
      "title": "CMSPage",
      "description": "Dynamic layout configuration blocks managed by admin",
      "type": "object",
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "blocks": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["slug", "title", "blocks"]
    }
  },
  "firestore": {
    "/publications/{pubId}": {
      "schema": { "$ref": "#/entities/Publication" },
      "description": "Contains research publications and texts"
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Contains research grants and active investigations"
    },
    "/blog/{blogId}": {
      "schema": { "$ref": "#/entities/BlogPost" },
      "description": "Contains news feed articles and commentaries"
    },
    "/gallery/{imageId}": {
      "schema": { "$ref": "#/entities/GalleryImage" },
      "description": "Contains archived photographs from academic functions"
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/ContactMessage" },
      "description": "Contains correspondence inquiries and messages"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Contains registered website visitors"
    },
    "/transactions/{txnId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Contains payment transactions"
    },
    "/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Contains moderated feedback comments on publications"
    },
    "/settings/{settingsId}": {
      "schema": { "$ref": "#/entities/DonationSettings" },
      "description": "Configuration for donations or payment operations"
    },
    "/favorites/{favId}": {
      "schema": { "$ref": "#/entities/FavoriteItem" },
      "description": "Individual bookmarks linked to user profiles"
    },
    "/pages/{slug}": {
      "schema": { "$ref": "#/entities/CMSPage" },
      "description": "Dynamic block configurations for visual CMS pages"
    }
  }
}
